{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "docs.datariot.xyz"
                }
            ],
            "destination": "/datariot-docs/"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "docs.datariot.xyz"
                }
            ],
            "destination": "/datariot-docs/:path*"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "info.datariot.xyz"
                }
            ],
            "destination": "/datariot-info/"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "info.datariot.xyz"
                }
            ],
            "destination": "/datariot-info/:path*"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "datariot.xyz"
                }
            ],
            "destination": "/datariot-xyz/"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "datariot.xyz"
                }
            ],
            "destination": "/datariot-xyz/:path*"
        }
    ]
}